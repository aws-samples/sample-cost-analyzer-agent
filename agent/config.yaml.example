# Cost Analyzer Agent - Deployment Configuration
# This file is used during agent deployment to AWS Bedrock AgentCore
#
# Quick setup:
#   1. Set your AWS region
#   2. Configure your accounts (payer + member)
#   3. Deploy with ./deploy.sh

# =============================================================================
# AWS Region
# =============================================================================
aws:
  region: us-east-1  # Your AWS region

# =============================================================================
# Account Configuration (REQUIRED — update with your account details)
# =============================================================================
#
# - Exactly one payer account is required (must have role_arn)
# - Member accounts may omit role_arn when the agent runs in the same account
# - Athena config can appear on any account type (payer or member)
# - The table field is optional — when omitted, the agent auto-discovers tables
#
# This example uses Scenario A: Centralized Logging Account
# The agent runs in a logging/analytics account that has both CUR and VPC Flow
# Log data in local Athena tables. The payer account is only needed for billing
# API calls (Cost Explorer, Budgets, etc.).

accounts:
  # Payer account — used for billing APIs only (Cost Explorer, Budgets, etc.)
  # role_arn is required because the agent never runs in the payer account.
  - account_id: "111111111111"
    role_arn: "arn:aws:iam::111111111111:role/CostAnalyzerAgentPayerRole"
    account_type: payer

  # Local logging account — agent runs here, no role_arn needed.
  # Both CUR and VPC Flow Log Athena tables are in this account.
  - account_id: "999999999999"
    account_type: member
    athena:
      cur:
        database: cur_db
        # table: cur_table  # Optional — omit to auto-discover
      vpc_flowlogs:
        database: vpc_db
        # table: flow_logs  # Optional — omit to auto-discover

# =============================================================================
# AgentCore Deployment Configuration
# =============================================================================
agentcore:
  execution_role_arn: ""  # Optional: IAM role ARN (leave empty for auto-creation)

# =============================================================================
# Agent Model Configuration
# =============================================================================
agent:
  model:
    provider: bedrock
    model_id: global.anthropic.claude-sonnet-4-5-20250929-v1:0
    temperature: 0.1
    max_tokens: 8192
    cache_tools: true  # Enable tool caching (reduces cost by ~90%)
    cache_ttl: "5m"    # Cache TTL: "5m" (interactive) or "1h" (batch)

# =============================================================================
# MCP (Model Context Protocol) Configuration
# =============================================================================
mcp:
  enabled: true
  servers:
    aws_knowledge:
      type: http
      url: https://knowledge-mcp.global.api.aws
      enabled: true

# =============================================================================
# Tools Configuration
# =============================================================================
tools:
  enabled:
    - date
    - athena
    - analysis
    - billing
    - mcp

# =============================================================================
# Alternative: Scenario B — Audit Account (Distributed Data)
# =============================================================================
# Use this instead of the accounts section above if the agent runs in a
# separate audit account. CUR data lives in the payer account, and VPC Flow
# Log data lives in individual member accounts. All accounts require role_arn
# for cross-account access via STS AssumeRole.
#
# accounts:
#   # Payer account — billing APIs and CUR Athena data
#   - account_id: "111111111111"
#     role_arn: "arn:aws:iam::111111111111:role/CostAnalyzerAgentPayerRole"
#     account_type: payer
#     athena:
#       cur:
#         database: cur_db
#         # table: cur_table  # Optional — omit to auto-discover
#
#   # Member account with VPC Flow Log data
#   - account_id: "222222222222"
#     role_arn: "arn:aws:iam::222222222222:role/CostAnalyzerAgentMemberRole"
#     account_type: member
#     athena:
#       vpc_flowlogs:
#         database: vpc_db
#         # table: flow_logs  # Optional — omit to auto-discover
#
#   # Another member account with VPC Flow Log data
#   - account_id: "333333333333"
#     role_arn: "arn:aws:iam::333333333333:role/CostAnalyzerAgentMemberRole"
#     account_type: member
#     athena:
#       vpc_flowlogs:
#         database: vpc_db
#         # table: flow_logs  # Optional — omit to auto-discover

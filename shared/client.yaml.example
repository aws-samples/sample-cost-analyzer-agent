# Cost Analyzer Agent - Client Configuration
# This file is used by both CLI and Frontend
# Auto-generated by deploy.sh after agent deployment

# AWS Configuration
aws:
  region: us-east-1  # Your AWS region

# AgentCore Configuration
agentcore:
  agent_id: ""  # Your deployed agent ID (auto-populated by deploy.sh)
  
# After deploying the agent with ./deploy.sh, this file will be automatically
# created with your agent ID. Both CLI and frontend will read from this file.
#
# Example after deployment:
#   agentcore:
#     agent_id: cost_analyzer_agent-5gTQmv5pqK
#
# Then you can use:
#   ./cli/cli.sh -q "What are my costs?"
#   cd frontend && streamlit run app.py
